# Anthropic API key for intelligent data extraction
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Subreddits to scan (comma-separated, no r/ prefix)
SUBREDDITS=NYCApartments,NYCHousing,ApartmentsForRent

# How often to scan in hours (default: 4)
SCAN_INTERVAL_HOURS=4

# Flask secret key (change this to a random string)
FLASK_SECRET_KEY=change-me-to-something-random
